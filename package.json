{
  "name": "course-ai-agents",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "slidev slides-ai-agents.md --port 3030 --strictPort --open",
    "dev:n8n": "slidev slides-n8n.md --port 3131 --strictPort --open",
    "build": "pnpm build:ai-agents && pnpm build:n8n",
    "build:ai-agents": "slidev build slides-ai-agents.md --base /course-ai-agents/ai-agents/ --out dist/ai-agents",
    "build:n8n": "slidev build slides-n8n.md --base /course-ai-agents/n8n/ --out dist/n8n",
    "export": "slidev export slides-ai-agents.md"
  },
  "devDependencies": {
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/ri": "^1.2.10",
    "@iconify-json/teenyicons": "^1.2.2",
    "@slidev/cli": "^52.17.0",
    "@slidev/theme-default": "^0.25.0",
    "@slidev/types": "^52.18.0",
    "@types/seedrandom": "^3.0.8",
    "prettier": "^3.9.5",
    "prettier-plugin-slidev": "^1.0.5",
    "seedrandom": "^3.0.5",
    "unocss": "66.7.3"
  },
  "dependencies": {
    "@iconify-json/iconoir": "^1.2.11",
    "slidev-addon-python-runner": "^0.1.3",
    "slidev-addon-window-mockup": "^0.3.1",
    "slidev-theme-dracula": "^0.2.5"
  }
}
